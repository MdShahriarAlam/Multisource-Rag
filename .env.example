# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=
MYSQL_USER=
MYSQL_PASSWORD=

# ── Google Cloud / BigQuery ───────────────────────────────────────────────────
# Path to a GCP service-account JSON key file (never commit the file itself)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=
BIGQUERY_DATASET=
GCS_BUCKET=

# ── Azure SQL ─────────────────────────────────────────────────────────────────
AZURE_SQL_SERVER=
AZURE_SQL_DB=
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=

# ── Azure Cosmos DB ───────────────────────────────────────────────────────────
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DB=

# ── Application ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8001
